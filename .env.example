# ==============================================================================
# Yahboom Rover Configurations Template (.env.example)
# Copy this file to '.env' and fill in your local system variables.
# ==============================================================================

# WiFi Credentials (git-ignored, used for RPi5 configuration)
WIFI_SSID=<your_wifi_ssid>
WIFI_PASSWORD=<your_wifi_password>

# RPi5 Deployment & Target Configurations
ROVER_PI_HOST=rover
ROVER_PI_USER=ron
ROVER_PI_PORT=22
ROVER_PI_APP_DIR=/home/ron/yahboom-encoder
ROVER_PI_SSH_KEY=

# Node Web Server & Serial Configurations
PORT=3000
ROVER_ESP32_DEVICE=/dev/rover-esp32
ROVER_LIDAR_DEVICE=/dev/rover-lidar
SERIAL_PORT=/dev/rover-esp32
BAUD_RATE=115200

# I2C Sidecar Configurations (Bypassed but kept for compatibility)
I2C_SIDECAR_URL=http://127.0.0.1:3001/data
I2C_PORT=3001
I2C_BUS=1
I2C_ADDRESS=0x34
I2C_INTERVAL=0.1
