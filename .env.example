# Environment variables configuration template for the Rover Pi Cockpit
# Copy to .env and replace placeholders with actual values (do not commit .env)

# RPi 5 Network Configuration
ROVER_PI_HOST=10.0.0.247
ROVER_PI_USER=ron
ROVER_PI_PORT=22

# Authentication methods (specify one)
# 1. Private key path (e.g. C:/Users/Ron/.ssh/id_rsa)
ROVER_PI_SSH_KEY=
# 2. RPi SSH Password
ROVER_PI_PASSWORD=replace_with_local_password
